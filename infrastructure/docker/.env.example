# Flowlet Docker Compose Environment Variables
#
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
#
# Generate secure secrets with:
#   openssl rand -base64 32

# PostgreSQL Configuration
POSTGRES_USER=flowlet
POSTGRES_PASSWORD=CHANGE_ME_generate_random_password
POSTGRES_DB=flowlet

# Redis Configuration
REDIS_PASSWORD=CHANGE_ME_generate_random_password

# Application Configuration
JWT_SECRET=CHANGE_ME_generate_random_jwt_secret
SECRET_KEY=CHANGE_ME_generate_random_secret_key

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8000

# External API Keys (Optional - for full functionality)
STRIPE_API_KEY=sk_test_your_stripe_key_here
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# Docker image tag
IMAGE_TAG=latest
REGISTRY=flowlet
