# API Configuration
VITE_API_BASE_URL=http://localhost:8000

# Environment
VITE_APP_ENV=development
VITE_APP_VERSION=2.0.0

# Feature Flags
VITE_ENABLE_DEMO_MODE=true
VITE_ENABLE_BIOMETRIC_AUTH=false
VITE_ENABLE_WORKFLOW_DESIGNER=true

# Analytics (optional)
VITE_ANALYTICS_KEY=

# Sentry (optional)
VITE_SENTRY_DSN=

# Stripe (optional, for embedded payments)
VITE_STRIPE_PUBLIC_KEY=
