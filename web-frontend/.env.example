# Flowlet Web Frontend — environment variables
# Copy this file to .env.local and fill in the values.

# URL of the Flowlet Flask backend (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Optional: Sentry DSN for frontend error tracking
# VITE_SENTRY_DSN=

# Optional: analytics
# VITE_ANALYTICS_ID=
