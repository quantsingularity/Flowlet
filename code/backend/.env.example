# ============================================================
# Flowlet Financial Backend - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Core Flask Settings
SECRET_KEY=your-secret-key-at-least-32-characters-long
FLASK_ENV=development
FLASK_CONFIG=development
PORT=5000

# Database (PostgreSQL for production, SQLite falls back for development)
DATABASE_URL=postgresql://flowlet:flowlet_pass@localhost:5432/flowlet_db
POSTGRES_USER=flowlet
POSTGRES_PASSWORD=flowlet_pass
POSTGRES_DB=flowlet_db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=redis_pass
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-at-least-32-characters-long
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=86400

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Encryption
ENCRYPTION_KEY=generate-with-cryptography-fernet-32-bytes-base64

# External Services
OPENAI_API_KEY=sk-your-openai-api-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret

# Email (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@flowlet.com
EMAIL_ENABLED=false

# SMS (Twilio)
SMS_ENABLED=false
SMS_PROVIDER=console
SMS_FROM_NUMBER=+10000000000
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token

# ACH Configuration
ACH_ENABLED=true
ACH_MOCK_MODE=true
ACH_COMPANY_NAME=Flowlet
ACH_COMPANY_ID=your-company-id

# Feature Flags
FRAUD_DETECTION_ENABLED=true
KYC_VERIFICATION_REQUIRED=true
AML_MONITORING_ENABLED=true
SANCTIONS_SCREENING_ENABLED=true
SANCTIONS_MOCK_MODE=true

# Monitoring
ERROR_TRACKING_ENABLED=true
METRICS_ENABLED=true
