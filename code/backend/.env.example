# Flowlet Backend — environment variables
# Copy to .env and fill in before running.

FLASK_ENV=development
FLASK_APP=app.py
PORT=8000

# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-change-in-production

# Database (defaults to SQLite for dev)
# DATABASE_URL=postgresql://user:password@localhost:5432/flowlet

# Redis (required for rate limiting in production)
# REDIS_URL=redis://localhost:6379/0

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Encryption key for sensitive fields (must be 32 bytes)
# ENCRYPTION_KEY=

# Optional: Sentry
# SENTRY_DSN=
